# 대회 데이터 — 재배포 금지 + GitHub 용량 제한 (train.jsonl 103MB)
data/
open.zip
*.jsonl

# 모델 산출물 / 제출물 (submit/model/ 폴더 구조는 추적, 무거운 파일만 제외)
submit/*.zip
submit/model/*
!submit/model/.gitkeep
submit_candidates/**/*.zip
output/
artifacts/
colab_out/

# 밤샘 러너 로그 (프롬프트·리포트·DONE은 추적, 실행 로그만 제외)
context/night/**/_runner/
*.pkl
*.joblib
*.pt
*.bin
*.safetensors

# Python
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# 도구 (.claude는 로컬 설정만 제외, 프로젝트 스킬·에이전트 정의는 추적)
.codegraph/
.claude/*
!.claude/skills/
!.claude/agents/

# OS
Thumbs.db
.DS_Store
